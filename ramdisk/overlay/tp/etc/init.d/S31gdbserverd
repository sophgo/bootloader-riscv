#!/bin/sh
#
# gdbserverd        Starts TP gdbserver2 (--multi) daemon
#

export LD_LIBRARY_PATH=/lib:/lib64:/usr/lib

[ -f /gdbserver2 ] || exit 0


GDBSERVER_LOG="/tmp/tp_gdbserver.log"
# GDBSERVER_LOG="/dev/null"
SUPERVISOR_PID_FILE="/var/run/gdbserver2-supervisor.pid"
RESTART_DELAY_SEC=1

umask 077

is_supervisor_running() {
        [ -f "$SUPERVISOR_PID_FILE" ] || return 1
        pid="$(cat "$SUPERVISOR_PID_FILE" 2>/dev/null)" || return 1
        [ -n "$pid" ] || return 1
        kill -0 "$pid" 2>/dev/null
}

start() {
        printf "Starting gdbserver2 supervisor (log: %s): " "$GDBSERVER_LOG"
        if is_supervisor_running; then
                echo "ALREADY RUNNING"
                return 0
        fi

        rm -f "$SUPERVISOR_PID_FILE"
        (
                trap 'exit 0' INT TERM
                while true; do
                        /gdbserver2 --multi 0.0.0.0:0 >>"$GDBSERVER_LOG" 2>&1
                        rc="$?"
                        printf "[%s] gdbserver2 exited (rc=%s), restarting in %ss\n" \
                                "$(date '+%Y-%m-%d %H:%M:%S')" "$rc" "$RESTART_DELAY_SEC" >>"$GDBSERVER_LOG"
                        sleep "$RESTART_DELAY_SEC"
                done
        ) &
        echo "$!" >"$SUPERVISOR_PID_FILE"
        echo "OK"
}

stop() {
        printf "Stopping gdbserver2 supervisor: "
        if is_supervisor_running; then
                pid="$(cat "$SUPERVISOR_PID_FILE" 2>/dev/null)"
                kill "$pid" 2>/dev/null || true
        fi
        rm -f "$SUPERVISOR_PID_FILE"
        killall gdbserver2 2>/dev/null || true
        echo "OK"
}

restart() {
        stop
        start
}

case "$1" in
  start)
    start
    ;;
  stop)
    stop
    ;;
  restart|reload)
    restart
    ;;
  *)
    echo "Usage: $0 {start|stop|restart}"
    exit 1
esac

exit $?
